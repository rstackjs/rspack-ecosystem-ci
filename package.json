{
  "name": "rspack-ecosystem-ci",
  "version": "0.0.1",
  "description": "Rspack Ecosystem CI",
  "scripts": {
    "prepare": "pnpm exec simple-git-hooks",
    "lint": "rslint && prettier -c .",
    "lint:fix": "rslint --fix && prettier -w .",
    "format": "prettier -c .",
    "format:fix": "prettier -w .",
    "test:self": "tsx ecosystem-ci.ts _selftest",
    "test": "tsx ecosystem-ci.ts",
    "bisect": "tsx ecosystem-ci.ts bisect"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm run lint:fix"
  },
  "type": "module",
  "engines": {
    "node": ">=18",
    "pnpm": "9.15.2"
  },
  "packageManager": "pnpm@9.15.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/web-infra-dev/rspack-ecosystem-ci.git"
  },
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/web-infra-dev/rspack-ecosystem-ci/issues"
  },
  "homepage": "https://github.com/web-infra-dev/rspack-ecosystem-ci#readme",
  "dependencies": {
    "@actions/cache": "^3.2.4",
    "@actions/core": "^1.10.0",
    "cac": "^6.7.14",
    "execa": "^7.1.1",
    "node-fetch": "^3.3.1"
  },
  "devDependencies": {
    "@antfu/ni": "^0.20.0",
    "@rslint/core": "^0.5.0",
    "@types/node": "^18.15.5",
    "@types/semver": "^7.3.13",
    "prettier": "^3.8.3",
    "semver": "^7.3.8",
    "simple-git-hooks": "^2.8.1",
    "tsx": "^3.12.6",
    "typescript": "^4.9.5",
    "verdaccio": "^6.1.5"
  }
}
